@startuml
skin rose
left to right direction
title Caso de uso "CU03 - Gestionar Usuarios, Roles y Permisos"

actor Administrador as admin

rectangle "Sistema COOPAC-CM" {
    usecase "◉\nCU03\nGestionar Usuarios" as CU03
    usecase "◻\nConsultar\nUsuarios" as CU
    usecase "◻\nEditar\nUsuario" as EU
    usecase "◻\nAsignar Roles" as AR
    usecase "◻\nAsignar Permisos" as AP
    usecase "▯\nValidar\nDatos" as VD
    usecase "▯\nEvitar quitar\nrol admin crítico" as PROT
    usecase "△\nMostrar\nMensaje de error" as ERR
}

admin --> CU03 : Administra
CU03 .> CU : <<include>>
CU03 .> EU : <<include>>
CU03 .> AR : <<include>>
CU03 .> AP : <<include>>
EU .> VD : <<include>>
AR .> PROT : <<include>>
AP .> PROT : <<include>>
ERR .> CU03 : <<extend>>

legend right
|= Símbolo |= Descripción |
| ◉ | Caso de uso principal |
| ◻ | Operaciones de gestión |
| ▯ | Validación o regla de negocio |
| △ | Flujo alternativo de error |
| --> | Asociación actor → caso de uso |
| ..> | Dependencia UML |
| <<include>> | Flujo obligatorio |
| <<extend>> | Flujo alternativo/excepcional |
endlegend
@enduml
