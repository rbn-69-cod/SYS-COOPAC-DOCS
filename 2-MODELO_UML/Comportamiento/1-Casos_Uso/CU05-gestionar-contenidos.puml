@startuml
left to right direction
!theme amiga
title CU05 - Gestionar Contenidos Públicos

actor "Responsable de Imagen" as imagen
actor "Administrador" as admin
actor "Visitante" as visitante

rectangle "Sistema COOPAC-CM" {
    usecase "◉\nCU05\nGestionar Contenidos" as CU05
    usecase "Crear/editar\nanuncios" as anuncios
    usecase "Configurar orden\ny vigencia" as vigencia
    usecase "Crear/editar\nnoticias" as noticias
    usecase "Publicar o guardar\ncomo borrador" as publicar
    usecase "Subir imagen\ny adjuntos" as archivos
    usecase "Mostrar contenido\nen sitio público" as mostrar
}

imagen --> CU05
admin --> CU05
visitante --> mostrar
CU05 .> anuncios : <<include>>
CU05 .> vigencia : <<include>>
CU05 .> noticias : <<include>>
CU05 .> publicar : <<include>>
CU05 .> archivos : <<include>>
mostrar .> anuncios : <<include>>
mostrar .> noticias : <<include>>
@enduml
