@startuml
left to right direction
!theme bluegray
skinparam footerFontColor black
title <size:20><b>CU02 - Logearse / Iniciar Sesión</b></size>

actor "Administrador" as admin
actor "Asesor" as asesor
actor "Responsable de Imagen" as imagen
actor "Responsable de RRHH" as rrhh

rectangle "Sistema COOPAC-CM" {
    usecase "◉\n<size:18><b>CU02</b></size>\nLogearse" as UC_Login
    usecase "Validar\ncredenciales" as UC_Validar
    usecase "Verificar roles\ny permisos" as UC_Roles
    usecase "Redirigir a\npanel según rol" as UC_Redirigir
    usecase "Registrar acceso\ndel usuario" as UC_Acceso
    usecase "⚠\nMostrar mensaje\nde error" as UC_Error
}

admin --> UC_Login : Accede
asesor --> UC_Login : Accede
imagen --> UC_Login : Accede
rrhh --> UC_Login : Accede

UC_Login .> UC_Validar : <<include>>
UC_Login .> UC_Roles : <<include>>
UC_Login .> UC_Redirigir : <<include>>
UC_Login .> UC_Acceso : <<include>>
UC_Error .> UC_Login : <<extend>>

legend right
|= Símbolo |= Descripción |
| ◉ | Caso de uso principal |
| ⚠ | Flujo alternativo de error |
| <<include>> | Flujo obligatorio |
| <<extend>> | Flujo alternativo/excepcional |
endlegend

footer
<b>COOPAC-CM</b>\nDiagramas UML - Casos de Uso\nPlantUML %version()
endfooter
@enduml
