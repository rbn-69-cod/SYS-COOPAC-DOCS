@startuml
left to right direction
!theme plain
title CU06 - Gestionar Asesores RRHH

actor "RRHH" as rrhh
actor "Administrador" as admin

rectangle "Sistema COOPAC-CM" {
    usecase "◉\nCU06\nGestionar Asesores" as CU06
    usecase "Registrar\nasesor" as registrar
    usecase "Editar datos\nde asesor" as editar
    usecase "Eliminar\nasesor" as eliminar
    usecase "Asignar rol\nasesor" as rol
    usecase "Asociar agencia" as agencia
    usecase "Validar datos" as validar
}

rrhh --> CU06
admin --> CU06
CU06 .> registrar : <<include>>
CU06 .> editar : <<include>>
CU06 .> eliminar : <<include>>
CU06 .> rol : <<include>>
CU06 .> agencia : <<include>>
registrar .> validar : <<include>>
editar .> validar : <<include>>
@enduml
