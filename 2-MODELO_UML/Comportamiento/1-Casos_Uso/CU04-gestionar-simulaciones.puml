@startuml
left to right direction
!theme cerulean-outline
title CU04 - Gestionar Simulaciones de Crédito

actor "Asesor" as asesor
actor "Administrador" as admin

rectangle "Sistema COOPAC-CM" {
    usecase "◉\nCU04\nGestionar Simulaciones" as CU04
    usecase "Consultar\nlista de leads" as listar
    usecase "Filtrar por datos\ny rango de fechas" as filtros
    usecase "Cambiar estado\nde simulación" as estado
    usecase "Exportar CSV/XLS" as exportar
    usecase "Eliminar\nregistros" as eliminar
    usecase "Validar permisos" as permisos
}

asesor --> CU04
admin --> CU04
CU04 .> listar : <<include>>
CU04 .> filtros : <<include>>
CU04 .> estado : <<include>>
CU04 .> exportar : <<include>>
CU04 .> eliminar : <<include>>
CU04 .> permisos : <<include>>
@enduml
