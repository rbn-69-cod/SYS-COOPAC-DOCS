@startuml
left to right direction
!theme bluegray
skinparam backgroundColor #F4FFF4
title <size:20><b>CU01 - Simular Crédito</b></size>

actor "Visitante" as visitante
actor "Prospecto" as prospecto

rectangle "Sistema COOPAC-CM" {
    usecase "◉\n<size:18><b>CU01</b></size>\nSimular Crédito" as UC_Simular
    usecase "Ingresar datos\npersonales" as UC_Datos
    usecase "Ingresar monto,\nplazo, tipo y agencia" as UC_Parametros
    usecase "Calcular TEA/TEM\ny cuota fija" as UC_Calculo
    usecase "Generar tabla de\namortización" as UC_Tabla
    usecase "Guardar prospecto\ncon estado nuevo" as UC_Guardar
    usecase "Mostrar resumen\nde simulación" as UC_Resumen
    usecase "⚠\nValidar datos\nobligatorios" as UC_Validar
}

visitante --> UC_Simular : Accede
prospecto --> UC_Simular : Completa formulario

UC_Simular .> UC_Datos : <<include>>
UC_Simular .> UC_Parametros : <<include>>
UC_Simular .> UC_Calculo : <<include>>
UC_Simular .> UC_Tabla : <<include>>
UC_Simular .> UC_Guardar : <<include>>
UC_Simular .> UC_Resumen : <<include>>
UC_Validar .> UC_Simular : <<extend>>

legend right
|= Símbolo |= Descripción |
| ◉ | Caso de uso principal |
| ⚠ | Flujo alternativo de validación |
| <<include>> | Flujo obligatorio |
| <<extend>> | Flujo alternativo |
endlegend

footer
<b>COOPAC-CM</b>\nDiagramas UML - Casos de Uso\nPlantUML %version()
endfooter
@enduml
