@startuml
title Diagrama de Clases - COOPAC-CM
skinparam classAttributeIconSize 0

'====================================
' ENUMS
'====================================
enum EstadoSimulacion {
  NUEVO
  CONTACTADO
  EN_EVALUACION
  APROBADO_PRELIMINAR
  DESCARTADO
}

enum EstadoNoticia {
  BORRADOR
  PUBLICADO
}

enum RolSistema {
  ADMIN
  ASESOR
  IMAGEN
  RRHH
}

'====================================
' USUARIOS Y SEGURIDAD
'====================================
class User {
  - id: int
  - name: String
  - email: String
  - password: String
  - email_verified_at: DateTime
  + assignRole(rol:String): void
  + syncRoles(roles:List): void
  + syncPermissions(permisos:List): void
}

class Role {
  - id: int
  - name: String
  - guard_name: String
}

class Permission {
  - id: int
  - name: String
  - guard_name: String
}

User "*" -- "*" Role : tiene >
User "*" -- "*" Permission : posee >
Role "*" -- "*" Permission : agrupa >

'====================================
' SIMULADOR Y SIMULACIONES
'====================================
class ProspectoCredito {
  - id: int
  - nombre: String
  - dni: String
  - celular: String
  - monto_solicitado: decimal
  - plazo_meses: int
  - tipo_credito: String
  - agencia: String
  - cuota_estimada: decimal
  - estado: EstadoSimulacion
  + registrar(): void
  + actualizarEstado(estado:String): void
}

class Simulacion {
  - id: int
  - nombre: String
  - dni: String
  - celular: String
  - monto: decimal
  - plazo: int
  - tipo: String
  - agencia: String
  - estado: EstadoSimulacion
  + filtrar(): Collection
  + exportarCSV(): File
  + exportarXLS(): File
}

class ProspectoCreditoController {
  + showForm(): View
  + store(request): RedirectResponse
  + calcularCuota(monto, plazo): decimal
  + generarTablaAmortizacion(): array
}

class SimulacionExportController {
  + csv(request): Response
  + xls(request): Response
}

ProspectoCreditoController --> ProspectoCredito : guarda >
SimulacionExportController --> Simulacion : exporta >
ProspectoCredito ..> Simulacion : alimenta panel >

'====================================
' CONTENIDOS PUBLICOS
'====================================
class Anuncio {
  - id: int
  - titulo: String
  - imagen: String
  - url: String
  - activo: boolean
  - orden: int
  - vigente_desde: Date
  - vigente_hasta: Date
  + vigentes(): Collection
}

class Noticia {
  - id: int
  - titulo: String
  - slug: String
  - descripcion: String
  - contenido: Text
  - imagen: String
  - adjunto: String
  - estado: EstadoNoticia
  - publicado_en: DateTime
  + publicar(): void
  + pasarABorrador(): void
}

class AnuncioController {
  + index(): View
  + create(): View
  + store(request): RedirectResponse
  + edit(id): View
  + update(request,id): RedirectResponse
  + destroy(id): RedirectResponse
}

class NoticiaController {
  + index(): View
  + create(): View
  + store(request): RedirectResponse
  + edit(id): View
  + update(request,id): RedirectResponse
  + destroy(id): RedirectResponse
}

AnuncioController --> Anuncio : gestiona >
NoticiaController --> Noticia : gestiona >

'====================================
' RRHH / ASESORES
'====================================
class Asesor {
  - id: int
  - user_id: int
  - nombres: String
  - agencia: String
  - estado: boolean
  + activar(): void
  + desactivar(): void
}

class AsesorController {
  + index(): View
  + create(): View
  + store(request): RedirectResponse
  + edit(id): View
  + update(request,id): RedirectResponse
  + destroy(id): RedirectResponse
}

AsesorController --> Asesor : administra >
User "1" -- "0..1" Asesor : perfil asesor >

'====================================
' BUSQUEDA Y SITIO PUBLICO
'====================================
class BusquedaController {
  + index(query): View
  + buscarNoticias(query): Collection
  + buscarAnuncios(query): Collection
}

BusquedaController --> Noticia : busca >
BusquedaController --> Anuncio : busca >

'====================================
' RELACIONES GENERALES
'====================================
User "1" --> "0..*" Simulacion : revisa/cambia estado >
User "1" --> "0..*" Anuncio : administra >
User "1" --> "0..*" Noticia : publica >
@enduml
